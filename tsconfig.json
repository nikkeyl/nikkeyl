{
  "compilerOptions": {
    // Editor Support
    "plugins": [
      {
        "name": "next"
      },
      {
        "name": "typescript-plugin-css-modules"
      }
    ],
    // Emit
    "noEmit": true,
    // Completeness
    "skipLibCheck": true,
    // JavaScript Support
    "allowJs": true,
    // Language and Environment
    "jsx": "preserve",
    "lib": ["DOM.Iterable", "DOM", "ESNext"],
    "target": "ESNext",
    // Modules
    "allowImportingTsExtensions": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@/config": ["./src/app/config/index.ts"],
      "@/data": ["./src/shared/data/index.ts"],
      "@/helpers": ["./src/shared/helpers/index.ts"],
      "@/icons": ["./src/shared/icons/index.ts"],
      "@/socials/*": ["./public/socials/*"],
      "@/styles/*": ["./src/app/styles/*"],
      "@/ui": ["./src/shared/ui/index.ts"],
      "@/widgets": ["./src/widgets/index.ts"]
    },
    "resolveJsonModule": true,
    // Projects
    "disableReferencedProjectLoad": true,
    "incremental": true,
    // Type Checking
    "allowUnreachableCode": false,
    "allowUnusedLabels": false,
    "exactOptionalPropertyTypes": true,
    "noImplicitAny": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "strict": true,
    // Interop Constraints
    "esModuleInterop": true,
    "isolatedModules": true
  },
  "exclude": ["node_modules"],
  "include": ["**/*.tsx", "**/*.ts", ".next/types/**/*.ts", "next-env.d.ts"]
}
